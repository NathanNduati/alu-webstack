#!/usr/bin/env bash
# Audits subdomains of a given domain using dig and awk

# Script arguments
DOMAIN=$1
SUBDOMAIN=$2

# Function to query and display subdomain info
audit_subdomain() {
    local sub=$1
    local dom=$2
    
    # Run dig, extract the answer line, and format output using awk
    # shellcheck disable=SC2086
    dig "${sub}.${dom}" | grep -A1 'ANSWER SECTION:' | tail -n 1 | awk -v s="$sub" '{print "The subdomain " s " is a " $4 " record and points to " $5}'
}

# Control flow based on arguments provided
if [ -z "$SUBDOMAIN" ]; then
    # Loop through the mandatory subdomains in their exact order
    for sub in www lb-01 web-01 web-02; do
        audit_subdomain "$sub" "$DOMAIN"
    done
else
    # Audit only the single specified subdomain
    audit_subdomain "$SUBDOMAIN" "$DOMAIN"
fi